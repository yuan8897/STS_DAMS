{
  "name": "sts-dams-backend",
  "version": "1.0.0",
  "description": "STS-DAMS 时空调度与动态资产管理系统 - 后端 API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "jest --config jest.config.js --forceExit",
    "test:skip-db": "SKIP_DB_TESTS=1 jest --config jest.config.js --forceExit",
    "restore-permissions": "node scripts/restore-permissions.js",
    "backup": "node scripts/backup-database.js",
    "backup:schema": "node scripts/backup-database.js --schema-only",
    "backup:seed": "node scripts/backup-database.js --seed-only"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.2",
    "mssql": "^11.0.1",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "supertest": "^7.2.2"
  }
}
