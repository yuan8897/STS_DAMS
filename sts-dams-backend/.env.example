# ========================================
# STS-DAMS Backend 环境变量配置
# 复制此文件为 .env 并修改实际值
# ========================================

# 服务器端口
PORT=8080

# SQL Server 数据库连接
# 默认实例: localhost | Express 版通常: localhost\SQLEXPRESS （反斜杠）
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=STS_DAMS
DB_USER=dams_user
DB_PASSWORD=your_db_password_here
# 设为 true 使用 Windows 集成认证（此时忽略 DB_USER/DB_PASSWORD）
DB_TRUSTED=false

# JWT 认证
JWT_SECRET=your_jwt_secret_key_change_me
JWT_EXPIRES_IN=7d

# AES 加密密钥（32 字节，用于敏感字段加密）
AES_ENCRYPTION_KEY=your_aes_256_key_32_bytes!

# 前端地址（CORS 白名单）
FRONTEND_URL=http://localhost:3000

# 日志级别: error | warn | info | debug
LOG_LEVEL=info

# 数据库连接池最大连接数（可选，默认 10）
DB_POOL_MAX=10
